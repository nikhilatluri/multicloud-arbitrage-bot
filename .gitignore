# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
wheels/
pip-wheel-metadata/
*.spec

# ── Virtual environments ───────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
.env/
virtualenv/

# ── Environment / secrets ──────────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.secret
secrets.json
credentials.json

# ── Local runtime data (generated by run_local.sh) ────────────────────────────
.local_bot.db
.local_bot.db-shm
.local_bot.db-wal
.local_logs/
.local_pids
.local_prometheus_data/
.local_grafana_data/
.local_grafana_plugins/
.local_grafana_provisioning/

# ── SQLite databases ──────────────────────────────────────────────────────────
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Docker ────────────────────────────────────────────────────────────────────
# keep docker-compose.yml and Dockerfiles — exclude generated volumes
.docker-data/

# ── OS artefacts ──────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── IDE / editors ─────────────────────────────────────────────────────────────
# JetBrains (keep .idea/vcs.xml and modules.xml for project structure)
.idea/*
!.idea/.gitignore
!.idea/modules.xml
!.idea/vcs.xml
!.idea/inspectionProfiles/

# VS Code — keep launch/settings for teammates, exclude personal/generated state
.vscode/*
!.vscode/launch.json
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/tasks.json

# ── Test / coverage artefacts ─────────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
nosetests.xml
coverage.xml
*.cover
junit*.xml

# ── Type checkers / linters ───────────────────────────────────────────────────
.mypy_cache/
.dmypy.json
.pyre/
.ruff_cache/

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── Node / frontend (if added later) ─────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-error.log
.yarn/
.pnp.*
